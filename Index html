<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MUTHAVVAL AVVAL - CLASS PORTAL</title>
    <style>
        :root { --primary: #044e33; --gold: #eab308; --bg: #f4f7f6; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); margin: 0; padding-bottom: 50px; }
        .header { background: var(--primary); color: white; text-align: center; padding: 20px; border-bottom: 4px solid var(--gold); }
        .page { display: none; padding: 15px; }
        .page.active { display: block; }
        .dashboard { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; padding: 15px; }
        .card { background: white; border-radius: 15px; padding: 20px; text-align: center; cursor: pointer; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .card-icon { font-size: 30px; margin-bottom: 5px; }
        .back-btn { background: var(--primary); color: white; padding: 8px 15px; border-radius: 5px; border: none; margin-bottom: 15px; }
        .list-item { background: white; padding: 12px; margin-bottom: 8px; border-radius: 8px; border-left: 5px solid var(--primary); }
    </style>
</head>
<body>

<div class="header"><h1>MUTHAVVAL AVVAL</h1></div>

<!-- HOME -->
<div id="homePage" class="page active">
    <div class="dashboard">
        <div class="card" onclick="showPage('teachersPage')"><div class="card-icon">👨‍🏫</div>TEACHERS</div>
        <div class="card" onclick="showPage('studentsPage')"><div class="card-icon">👨‍🎓</div>STUDENTS</div>
        <div class="card" onclick="showPage('attendancePage')"><div class="card-icon">📝</div>ATTENDANCE</div>
        <div class="card" onclick="showPage('timetablePage')"><div class="card-icon">📅</div>TIMETABLE</div>
        <div class="card" onclick="showPage('notificationPage')"><div class="card-icon">📢</div>UPDATIONS</div>
        <div class="card" onclick="showPage('maktabaPage')"><div class="card-icon">📚</div>MAKTABA</div>
    </div>
</div>

<!-- PAGES -->
<div id="teachersPage" class="page"><button class="back-btn" onclick="showPage('homePage')">← Back</button><div id="tList"></div></div>
<div id="studentsPage" class="page"><button class="back-btn" onclick="showPage('homePage')">← Back</button><div id="sList"></div></div>
<div id="attendancePage" class="page"><button class="back-btn" onclick="showPage('homePage')">← Back</button><h3>Daily Attendance</h3><input type="date" id="datePicker"><div id="attList"></div><button class="back-btn" onclick="saveAtt()">Save Attendance</button></div>
<div id="maktabaPage" class="page"><button class="back-btn" onclick="showPage('homePage')">← Back</button><h3>Library (Admin Only)</h3><input type="file" id="pdfFile"><button class="back-btn" onclick="uploadPdf()">Upload PDF</button><div id="mList"></div></div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js";
    import { getDatabase, ref, set, onValue } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-database.js";
    import { getStorage, ref as sRef, uploadBytes, getDownloadURL } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-storage.js";

    const config = { apiKey: "AIzaSyDJ1zCtLq5K2qFKp1C3zQFL_ijrb2z19WM", databaseURL: "https://muthavval-portal-default-rtdb.asia-southeast1.firebasedatabase.app", projectId: "muthavval-portal", storageBucket: "muthavval-portal.firebasestorage.app" };
    const app = initializeApp(config);
    const db = getDatabase(app);
    const storage = getStorage(app);

    // Data
    const teachers = [
        {name: "Perod Usthad", sub: "تحفة المحتاج"}, {name: "Shaheer Usthad", sub: "منهج البحث + علم الحديث"},
        {name: "Ibrahim Usthad", sub: "صحيح البخاري"}, {name: "Saeed Usthad", sub: "صحيح مسلم"},
        {name: "Muthalib Usthad", sub: "تحلي"}, {name: "Thangal Usthad", sub: "السراج المنير"},
        {name: "Sa-adi Usthad", sub: "الرسالة القشيرية + العربية المعاصرة"}, {name: "Umar Usthad", sub: "محلي"},
        {name: "Suraqath Usthad", sub: "التجويد"}, {name: "Thrikarippur Usthad", sub: "الفقه المعاصر"}
    ];

    const students = ["ABDUL SAMAD", "ISHAK E", "ISMAYIL C.K", "FAIZ", "JUMAN", "NABEEL. M", "SHAFEEKH K V", "SWALIH MANIYUR", "ALTHAF AS", "ALTHAF K R", "AMEEN P", "FAJRAN C H", "IRSHAD.T.M", "ISMAYIL T", "JADUL HACK", "JUNAID .K.M", "RISHAD E P", "SALIH. PV KAKKAD", "SHAMMAS. P.K", "SHANID N K", "SHIBILI N O", "SINAN A P", "SWALIH KANIYAMBATTA", "MANSOOR K", "QALEELULLA C H", "SAFAL HUSAIN .TK", "SAJAD K", "SWALIH PULLUKKARA", "SYD ASHFAQU RAHMAN", "ZUHAIR"];

    // UI Rendering
    window.showPage = (id) => {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    };

    document.getElementById('tList').innerHTML = teachers.map(t => `<div class="list-item"><b>${t.name}</b><br>${t.sub}</div>`).join('');
    document.getElementById('sList').innerHTML = students.map((s, i) => `<div class="list-item">${i+1}. ${s}</div>`).join('');

    // Attendance
    window.saveAtt = () => {
        const date = document.getElementById('datePicker').value;
        if(!date) return alert("Select Date");
        alert("Attendance saved for " + date);
    };

    // PDF Upload
    window.uploadPdf = async () => {
        const file = document.getElementById('pdfFile').files[0];
        if(!file) return;
        const fileRef = sRef(storage, 'library/' + file.name);
        await uploadBytes(fileRef, file);
        const url = await getDownloadURL(fileRef);
        set(ref(db, 'library/' + Date.now()), { name: file.name, url: url });
        alert("Uploaded!");
    };

    // Back Button Logic
    let count = 0;
    window.addEventListener('popstate', () => {
        count++;
        if(count == 2) window.close();
        else { alert("Press back again to exit"); history.pushState(null, null, location.href); }
    });
    history.pushState(null, null, location.href);
</script>
</body>
</html>
